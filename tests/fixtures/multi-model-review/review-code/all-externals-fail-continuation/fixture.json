{
  "scenario": "all-externals-fail-continuation",
  "description": "Above-threshold diff triggers multi-model dispatch; both external adapters (codex-review-prompter, gemini-review-prompter) fail with cli_missing. FR-MR17: native-only continuation with verbatim warning and audit-artifact continuation_event.",
  "input": {
    "command": "review-code",
    "target": "staged changes",
    "diff_stats": {
      "lines_changed": 78,
      "files_touched": 4,
      "files": [
        "src/api/notifications.ts",
        "src/services/notificationService.ts",
        "src/models/notification.ts",
        "src/workers/notificationWorker.ts"
      ]
    }
  },
  "config": {
    "multi_model_review": {
      "enabled": true,
      "per_command": {
        "review_code": {
          "enabled": true,
          "complexity_gate": {
            "threshold_lines_changed": 50,
            "threshold_files_touched": 3,
            "always_escalate_paths": [
              "**/auth/**",
              "**/payments/**",
              "**/billing/**",
              "**/migrations/**",
              "**/security/**",
              "**/secrets/**",
              "**/crypto/**"
            ]
          }
        }
      },
      "reviewers": [
        "codex-review-prompter",
        "gemini-review-prompter"
      ]
    }
  },
  "invocation_flags": {},
  "external_failures": [
    { "reviewer_id": "codex-review-prompter", "error_code": "cli_missing" },
    { "reviewer_id": "gemini-review-prompter", "error_code": "cli_missing" }
  ],
  "expected_routing": "multi-model",
  "expected_continuation": "native-only",
  "expected_warning_verbatim": "All external reviewers failed; continuing with natives only",
  "expected_continuation_type": "all-externals-failed"
}
