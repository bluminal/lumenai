{
  "scenario": "pool-match-native-only",
  "description": "Pool with matching roster (code-reviewer, security-reviewer), multi_model=false, prefer-with-fallback mode. Pool is idle and TTL has not expired.",
  "setup": {
    "index_json": {
      "pools": [
        {
          "name": "review-pool-a",
          "roster": ["code-reviewer", "security-reviewer"],
          "pool_state": "idle",
          "multi_model": false,
          "last_active_at": "2026-04-26T05:00:00Z",
          "ttl_minutes": 60,
          "metadata_dir": "~/.claude/teams/standing/review-pool-a"
        }
      ]
    },
    "config": {
      "standing_pools": {
        "enabled": true,
        "routing_mode": "prefer-with-fallback",
        "matching_mode": "covers"
      }
    },
    "command_args": {
      "target": "staged"
    }
  },
  "expected": {
    "routing_decision": "routed-to-pool",
    "pool_name": "review-pool-a",
    "multi_model": false,
    "notification_contains": "multi-model: no",
    "notification_absent": "multi-model: yes",
    "error": null
  }
