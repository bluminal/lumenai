{
  "scenario": "pool-match-multi-model",
  "description": "Pool with matching roster (code-reviewer, security-reviewer), multi_model=true, prefer-with-fallback mode. Notification must contain '(multi-model: yes)' and report carries multi-model attribution.",
  "setup": {
    "index_json": {
      "pools": [
        {
          "name": "review-pool-b",
          "roster": ["code-reviewer", "security-reviewer"],
          "pool_state": "idle",
          "multi_model": true,
          "last_active_at": "2026-04-26T05:00:00Z",
          "ttl_minutes": 60,
          "metadata_dir": "~/.claude/teams/standing/review-pool-b"
        }
      ]
    },
    "config": {
      "standing_pools": {
        "enabled": true,
        "routing_mode": "prefer-with-fallback",
        "matching_mode": "covers"
      }
    },
    "command_args": {
      "target": "staged"
    }
  },
  "expected": {
    "routing_decision": "routed-to-pool",
    "pool_name": "review-pool-b",
    "multi_model": true,
    "notification_contains": "multi-model: yes",
    "notification_absent": "multi-model: no",
    "report_attribution": "Review path: standing pool 'review-pool-b' (multi-model: yes).",
    "error": null
  }
}
