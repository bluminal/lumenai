        "matching_mode": "covers"
      }
    },
    "command_args": {
      "target": "staged"
    }
  },
  "expected": {
    "routing_decision": "fell-back-no-pool",
    "pool_name": null,
    "multi_model": null,
    "notification_contains": null,
    "fallback_type": "fresh-spawn",
    "error": null,
    "error_shown": false
  }
}
