{
  "scenario": "tty-suppressed-waiting-indicator",
  "description": "Pool matches; stdout is NOT a TTY (CI simulation); expected wait > 60s. Waiting indicator must NOT be emitted. Submission completes normally.",
  "setup": {
    "index_json": {
      "pools": [
        {
          "name": "review-pool-ci",
