          "pool_state": "idle",
          "multi_model": false,
          "last_active_at": "2026-04-26T05:00:00Z",
          "ttl_minutes": 60,
          "metadata_dir": "~/.claude/teams/standing/review-pool-ci"
        }
      ]
    },
    "config": {
      "standing_pools": {
        "enabled": true,
        "routing_mode": "prefer-with-fallback",
