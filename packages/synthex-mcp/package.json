{
  "name": "@synthex/mcp-server",
  "version": "0.1.0",
  "description": "MCP server exposing Synthex agents, commands, and tools to Claude Desktop",
  "type": "module",
  "main": "server/index.js",
  "scripts": {
    "build": "tsup && node scripts/copy-assets.js",
